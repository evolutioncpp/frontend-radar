{
  "extends": "./tsconfig.app.json",
  "compilerOptions": {
    "paths": {
      "@/*": ["src/*"],
      "@locales/*": ["./public/locales/*"]
    },
    "types": ["vite/client", "vitest/globals", "vitest/jsdom", "node"],
    "noEmit": true
  },
  "include": [
    "src",
    "public/locales/**/*.json",
    "e2e",
    "vite.config.ts",
    "vitest.config.ts",
    "playwright.config.ts"
  ]
}
