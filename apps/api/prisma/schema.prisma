generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ReportAnalysisStatus {
  queued
  running
  completed
  failed
}

enum ReportProjectPathSource {
  autodetect
  url
  manual
}

enum ReportAnalysisProgressStage {
  queued
  starting
  repository_metadata
  project_detection
  repository_signals
  source_scan
  workflow_analysis
  scoring
  report_building
}

model ReportAnalysis {
  id                String               @id @default(cuid())
  owner             String
  repository        String
  repositoryKey     String
  branch            String               @default("")
  projectPath       String               @default("")
  projectPathSource ReportProjectPathSource @default(autodetect)
  normalizedUrl     String
  status            ReportAnalysisStatus @default(queued)
  snapshotKey       String
  latestCommitSha   String?
  latestCommitDate  String?
  latestCommitTitle String?
  analysisVersion   Int                  @default(1)
  report            Json?
  errorCode         String?
  errorMessage      String?
  progressStage     ReportAnalysisProgressStage @default(queued)
  progressUpdatedAt DateTime             @default(now())
  isHistoryVisible  Boolean              @default(true)
  scoreCategoriesKey String              @default("documentation,testing,ci,dependencies,maintainability,performance,accessibility")
  leaseOwner        String?
  leaseExpiresAt    DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@unique([repositoryKey, projectPath, branch, snapshotKey, analysisVersion, scoreCategoriesKey, isHistoryVisible], map: "ReportAnalysis_dedupe_options_key")
  @@index([createdAt])
  @@index([updatedAt])
  @@index([isHistoryVisible, repositoryKey, projectPath, branch, status, updatedAt], map: "ReportAnalysis_history_options_idx")
  @@index([status, leaseExpiresAt, updatedAt], map: "ReportAnalysis_recovery_lease_idx")
}
