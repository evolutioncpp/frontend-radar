{
  "name": "@frontend-radar/api",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/main.js",
    "lint": "eslint . --max-warnings=0",
    "test": "vitest run",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "db:generate": "prisma generate --schema prisma/schema.prisma",
    "db:deploy": "prisma migrate deploy --schema prisma/schema.prisma",
    "db:migrate": "prisma migrate dev --schema prisma/schema.prisma",
    "db:studio": "prisma studio --schema prisma/schema.prisma"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@frontend-radar/github-repository": "file:../../packages/github-repository",
    "@frontend-radar/localization": "file:../../packages/localization",
    "@prisma/client": "^6.19.3",
    "fastify": "^5.6.2",
    "fastify-type-provider-zod": "^6.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.4",
    "eslint": "^9.39.4",
    "prettier": "^3.8.3",
    "prisma": "^6.19.3",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vitest": "^4.1.8"
  }
}
