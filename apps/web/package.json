{
  "name": "@frontend-radar/web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:host": "vite --host",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "lint": "eslint . --max-warnings=0",
    "format": "prettier --write . --ignore-path ../../.prettierignore",
    "format:check": "prettier --check . --ignore-path ../../.prettierignore",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "e2e": "playwright test",
    "e2e:ui": "playwright test --ui",
    "e2e:report": "playwright show-report",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "scss:types": "typed-scss-modules \"src/**/*.module.scss\" --exportType default --nameFormat none --implementation sass --includePaths src",
    "scss:types:watch": "typed-scss-modules \"src/**/*.module.scss\" --exportType default --nameFormat none --implementation sass --includePaths src --watch",
    "scss:types:check": "typed-scss-modules \"src/**/*.module.scss\" --exportType default --nameFormat none --implementation sass --includePaths src --listDifferent",
    "check": "npm run scss:types:check && npm run format:check && npm run lint && npm run build && npm run test && npm run e2e"
  },
  "dependencies": {
    "@hookform/resolvers": "^5.4.0",
    "@reduxjs/toolkit": "^2.12.0",
    "clsx": "^2.1.1",
    "i18next": "^26.3.0",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^4.0.0",
    "lucide-react": "^1.17.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.77.0",
    "react-i18next": "^17.0.8",
    "react-redux": "^9.3.0",
    "react-router-dom": "^7.16.0",
    "recharts": "^3.8.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@conarti/eslint-plugin-feature-sliced": "^1.0.5",
    "@eslint/js": "^9.39.4",
    "@playwright/test": "^1.60.0",
    "@storybook/react-vite": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.16",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.1",
    "@vitest/coverage-v8": "^4.1.8",
    "@vitest/ui": "^4.1.8",
    "eslint": "^9.39.4",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^5.5.6",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "prettier": "^3.8.3",
    "sass": "^1.100.0",
    "typed-scss-modules": "^8.1.1",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12",
    "vite-plugin-svgr": "^5.2.0",
    "vitest": "^4.1.8"
  }
}
